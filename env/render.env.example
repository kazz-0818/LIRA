# =============================================================================
# Veriora 組織OS — 環境変数（新規キーは docs/env-conventions.md）
# - 既存キー名は削除しないでください。
# =============================================================================
#
# Render（LIRA 単体サービス）用の環境変数例
# Render ダッシュボードの Environment に同名で登録する。

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_SUMMARY=月次サマリー
SHEET_RECEIVABLES=入金予定
SHEET_PAYABLES=支払予定
HEADER_ROW=1
DATA_START_ROW=2
MAX_DATA_ROWS=5000

PUBLIC_APP_URL=https://your-lira-service.onrender.com

# --- OpenAI / Supabase / LINE（任意）---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_AUDIT_TABLE=lira_audit_log
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
