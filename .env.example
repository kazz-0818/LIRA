# LIRA 環境変数テンプレート（.env にコピーして値を埋める）
# 秘密はコミットしない

# --- Google Sheets ---
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_SUMMARY=月次サマリー
SHEET_RECEIVABLES=入金予定
SHEET_PAYABLES=支払予定
HEADER_ROW=1
DATA_START_ROW=2
MAX_DATA_ROWS=5000

# --- 公開 URL ---
PUBLIC_APP_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_AUDIT_TABLE=lira_audit_log

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- LINE ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
