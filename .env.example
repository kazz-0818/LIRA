# =============================================================================
# Veriora 組織OS — 環境変数（新規キーは docs/env-conventions.md に従う）
# - 共通推奨: VERIORA_*（Phase 3 で Settings の互換 alias 予定）
# - 本サービス（LIRA）固有: LIRA_* 推奨（現状は LINE_* 等の既存名を維持）
# - 既存キー名は後方互換のため削除しないでください。
# =============================================================================
#
# LIRA 環境変数テンプレート（.env にコピーして値を埋める）
# 秘密はコミットしない

# --- Google Sheets ---
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_SUMMARY=月次サマリー
SHEET_RECEIVABLES=入金予定
SHEET_PAYABLES=支払予定
HEADER_ROW=1
HEADER_ROW_AUTO=true
DATA_START_ROW=2
MAX_DATA_ROWS=5000

# --- 公開 URL ---
PUBLIC_APP_URL=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_AUDIT_TABLE=lira_audit_log

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- LINE ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
